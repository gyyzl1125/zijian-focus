    "test:planner-dom": "node --test tests/daily-planner-dom.test.cjs",
    "test:planner-adoption": "node --test tests/daily-planner-adoption.test.cjs",
    "test:entity-deletion": "node --test tests/entity-deletion.test.cjs",
    "test:task-deletion": "node --test tests/task-deletion.test.cjs",
    "test:memo-deletion": "node --test tests/memo-deletion.test.cjs",
    "test:planner-schedule": "node --test tests/planner-schedule.test.cjs",
    "test:week-layout": "node --test tests/week-layout.test.cjs",
    "test:week-gesture": "node --test tests/week-gesture.test.cjs",
    "test:mobile-week-schedule": "node --test tests/mobile-week-schedule.test.cjs",
    "test:activity-sessions": "node --test tests/activity-sessions.test.cjs",
    "test:activity-sync": "node --test tests/activity-sync.test.cjs",
    "test:activity-timeline": "node --test tests/activity-timeline.test.cjs",
    "test:habits": "node --test tests/habits.test.cjs",
