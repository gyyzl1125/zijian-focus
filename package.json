    "test:deadline-sprint-adoption": "node --test tests/deadline-sprint-adoption.test.cjs",
    "test:web-assets": "node --test tests/web-assets.test.cjs",
    "web:prepare": "node scripts/prepare-web.cjs prepare",
    "web:check": "node scripts/prepare-web.cjs check",
    "cap:add:android": "cap add android",
    "cap:copy": "cap copy android",
    "cap:sync": "cap sync android",
    "android:prepare": "npm run web:prepare && npm run web:check && npm run cap:sync",
    "android:build": "npm run android:prepare && cd android && gradlew.bat assembleDebug"
