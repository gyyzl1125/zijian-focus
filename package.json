{
  "name": "zijian-focus",
  "version": "0.1.0",
  "private": true,
  "description": "自见专注与日程安卓应用原型",
  "scripts": {
    "start": "python -m http.server 5174 --bind 0.0.0.0",
    "test:planner": "node --test tests/daily-planner.test.cjs",
    "test:planner-dom": "node --test tests/daily-planner-dom.test.cjs",
    "test:planner-adoption": "node --test tests/daily-planner-adoption.test.cjs",
    "test:entity-deletion": "node --test tests/entity-deletion.test.cjs",
